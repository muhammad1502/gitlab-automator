{
  "manifest_version": 3,
  "name": "Ninpo GitLab Accelerator",
  "version": "2.0",
  "description": "One-click triage and custom hotkeys for GitLab tickets.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "options.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://dojo.ninpo.com/*",
        "*://*.gitlab.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}